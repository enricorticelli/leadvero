generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64"]
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  passwordHash        String
  role                String    @default("user")
  mustChangePassword  Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?
}

model SearchJob {
  id              String   @id @default(cuid())
  keyword         String?
  niche           String?
  country         String
  city            String?
  language        String
  targetPlatform  String   @default("any")
  businessType    String?
  maxResults      Int      @default(30)
  filters         String?
  status          String   @default("pending")
  errorMessage    String?
  discoveredCount Int      @default(0)
  scannedCount    Int      @default(0)
  scoredCount     Int      @default(0)
  createdAt       DateTime @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  leads           Lead[]

  @@index([status, createdAt])
}

model Lead {
  id                    String   @id @default(cuid())
  searchJobId           String
  searchJob             SearchJob @relation(fields: [searchJobId], references: [id], onDelete: Cascade)

  companyName           String?
  domain                String
  normalizedDomain      String   @unique
  sourceUrl             String?
  sourceType            String?
  country               String?
  city                  String?
  language              String?
  niche                 String?
  businessType          String?

  cms                   String?
  ecommercePlatform     String?
  hasBlog               Boolean  @default(false)
  hasContactPage        Boolean  @default(false)
  publicEmail           String?
  publicPhone           String?
  hasForm               Boolean  @default(false)
  socialLinks           String?

  seoSignals            String?
  analyticsPresent      Boolean  @default(false)
  tagManagerPresent     Boolean  @default(false)
  performanceEstimate   Int?
  siteQualityNotes      String?

  fitScore              Int      @default(0)
  opportunityScore      Int      @default(0)
  commercialScore       Int      @default(0)
  contactabilityScore   Int      @default(0)
  totalScore            Int      @default(0)
  scoreReasons          String?

  status                String   @default("new")
  userNotes             String?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  lastScannedAt         DateTime?

  scans                 ScanResult[]
  analysisRuns          LeadAnalysisRun[]

  @@index([searchJobId])
  @@index([totalScore])
  @@index([status])
}

model LeadAnalysisRun {
  id                          String   @id @default(cuid())
  leadId                      String
  lead                        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  status                      String   @default("pending")
  preset                      String
  maxPages                    Int
  runTimeoutMs                Int
  includeBlogAndProductPaths  Boolean  @default(true)

  discoveredCount             Int      @default(0)
  scannedCount                Int      @default(0)
  summary                     String?
  errorMessage                String?

  createdAt                   DateTime @default(now())
  startedAt                   DateTime?
  finishedAt                  DateTime?
  updatedAt                   DateTime @updatedAt

  pages                       LeadAnalysisPage[]

  @@index([leadId, createdAt])
  @@index([status, createdAt])
}

model LeadAnalysisPage {
  id                String   @id @default(cuid())
  runId             String
  run               LeadAnalysisRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  scannedUrl        String
  pageType          String   @default("other")
  httpStatus        Int?
  title             String?
  metaDescription   String?
  h1                String?
  canonical         String?
  robotsMeta        String?
  schemaPresent     Boolean  @default(false)
  indexable         Boolean  @default(true)
  titleQuality      String?
  issues            String?
  notes             String?
  scannedAt         DateTime @default(now())

  @@index([runId, scannedAt])
}

model ScanResult {
  id               String   @id @default(cuid())
  leadId           String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  scannedUrl       String
  pageType         String   @default("other")
  httpStatus       Int?
  title            String?
  metaDescription  String?
  h1               String?
  canonical        String?
  robotsMeta       String?
  structuredData   String?
  notes            String?
  scannedAt        DateTime @default(now())

  @@index([leadId])
}
